# ---- Parent Helper Bot — environment ----
# Copy to .env and fill in. NEVER commit .env.

# Telegram
TELEGRAM_BOT_TOKEN=            # from @BotFather
TELEGRAM_WEBHOOK_SECRET=       # random string; verifies inbound webhook calls
PUBLIC_BASE_URL=               # https://your-host  (for webhook mode; empty = long-polling)

# LLM (pick one). If blank -> deterministic StubLLM (English, on-rails) is used.
LLM_PROVIDER=stub              # stub | openai | anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=                     # e.g. gpt-4o / claude-3-7-sonnet ; provider default if blank

# Speech-to-text. If blank -> StubSTT (echoes a fixed phrase) for local/dev.
STT_PROVIDER=stub              # stub | openai | deepgram
DEEPGRAM_API_KEY=

# Text-to-speech (voice replies to voice messages). If stub -> no voice replies.
TTS_PROVIDER=stub              # stub | openai (gpt-4o-mini-tts)
TTS_VOICE=alloy                # alloy | echo | fable | onyx | nova | shimmer | ...

# Email escalation. If blank -> StubEmail (logs only).
EMAIL_PROVIDER=stub            # stub | smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=helper@parent-helper.app

# Storage
DATABASE_URL=sqlite:///parent_helper.db   # prod: postgresql+psycopg://user:pass@host/db

# Privacy
DATA_RETENTION_DAYS=30         # transcripts/media older than this are purged
LOG_LEVEL=INFO

# Telegram Mini App (webapp). Empty WEBAPP_URL = all Mini App features off.
WEBAPP_URL=                    # public https URL of the Mini App (e.g. cloudflared tunnel)
WEBAPP_PORT=8081
WEBAPP_DIST=webapp/dist        # built frontend, relative to repo root
WEBAPP_AUTH_MAX_AGE=3600       # max initData age in seconds
WEBAPP_INSECURE_DEV=           # "1" ONLY on a dev machine: accepts "Authorization: dev <tg_id>"
TELEGRAM_BOT_USERNAME=         # e.g. made_with_care_bot (used for join links; getMe fallback)
